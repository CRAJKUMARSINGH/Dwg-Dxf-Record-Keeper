# --- Git LFS tracking ----------------------------------------------------
# Large binary CAD / reference assets must NEVER be stored as regular git
# blobs.  They live in Git LFS (or, for very large bundles, are published
# as release assets — see reference_drawings/README.md).
#
# Track every common CAD / drawing / heavy-binary extension found in
# practice on Indian bridge-design desks.

# AutoCAD & DXF interchange
*.dwg            filter=lfs diff=lfs merge=lfs -text
*.dxf            filter=lfs diff=lfs merge=lfs -text
*.dwf            filter=lfs diff=lfs merge=lfs -text
*.dwfx           filter=lfs diff=lfs merge=lfs -text
# Bentley / MicroStation
*.dgn            filter=lfs diff=lfs merge=lfs -text
# Documents (scanned hand-drafted sheets are usually PDF/TIFF)
*.pdf            filter=lfs diff=lfs merge=lfs -text
*.tif            filter=lfs diff=lfs merge=lfs -text
*.tiff           filter=lfs diff=lfs merge=lfs -text
# Raster images embedded as drawing references (scans, photos)
*.png            filter=lfs diff=lfs merge=lfs -text
*.jpg            filter=lfs diff=lfs merge=lfs -text
*.jpeg           filter=lfs diff=lfs merge=lfs -text
# Office binaries that often hold bulky charts / embedded images
*.xlsx           filter=lfs diff=lfs merge=lfs -text
*.xlsm           filter=lfs diff=lfs merge=lfs -text
*.docx           filter=lfs diff=lfs merge=lfs -text
*.pptx           filter=lfs diff=lfs merge=lfs -text
# Archives bundling reference drawings
*.zip            filter=lfs diff=lfs merge=lfs -text
*.7z             filter=lfs diff=lfs merge=lfs -text
*.rar            filter=lfs diff=lfs merge=lfs -text
# --- Line-ending hygiene -------------------------------------------------
*.py             text eol=lf
*.json           text eol=lf
*.yaml           text eol=lf
*.yml            text eol=lf
*.md             text eol=lf
